<ui:FluentWindow x:Class="EventScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:EventScanner.ViewModels"
        xmlns:helpers="clr-namespace:EventScanner.Helpers"
        Title="EventScanner"
        Height="750"
        Width="1100"
        MinHeight="500"
        MinWidth="700"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <helpers:SeverityToBrushConverter x:Key="SeverityToColor" />
        <helpers:SeverityToBackgroundConverter x:Key="SeverityToBg" />
        <helpers:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibilityConverter" />
    </ui:FluentWindow.Resources>

    <!-- Outer wrapper: animation canvas behind content -->
    <Grid Background="#0B0615">

        <!-- Neon butterfly / unicorn animation canvas -->
        <Canvas x:Name="AnimationCanvas"
                IsHitTestVisible="False"
                ClipToBounds="True" />

        <!-- Main content layer -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <ui:TitleBar Grid.Row="0" Title="EventScanner" />

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="32,8,32,16">
            <StackPanel MaxWidth="800">

                <!-- ═══ GRADE DISPLAY WITH VISUAL EFFECTS ═══ -->
                <Border x:Name="GradeSection"
                        Visibility="{Binding HasScanned, Converter={StaticResource BoolToVis}}"
                        Background="#08FFFFFF"
                        CornerRadius="16"
                        BorderThickness="1.5"
                        Padding="32,28"
                        Margin="0,8,0,16"
                        HorizontalAlignment="Stretch"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="GradeSectionScale" ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <Grid>
                        <!-- Radial aura background -->
                        <Ellipse Width="350" Height="200"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 IsHitTestVisible="False"
                                 Opacity="0.15">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="{Binding GradeBrush.Color}" Offset="0" />
                                    <GradientStop Color="Transparent" Offset="1" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                From="0.1" To="0.25"
                                                Duration="0:0:3">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>

                    <StackPanel HorizontalAlignment="Center">

                        <!-- Grade letter with glow layers -->
                        <Grid HorizontalAlignment="Center"
                              Margin="0,0,0,4">

                            <!-- Glow Layer 1: Soft wide glow (always visible) -->
                            <TextBlock Text="{Binding GradeDisplayName}"
                                       FontSize="80"
                                       FontWeight="Bold"
                                       Foreground="{Binding GradeBrush}"
                                       HorizontalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Effect>
                                    <BlurEffect Radius="{Binding GlowRadius}" />
                                </TextBlock.Effect>
                                <TextBlock.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="Opacity"
                                                    From="0.25" To="0.6"
                                                    Duration="0:0:2.5">
                                                    <DoubleAnimation.EasingFunction>
                                                        <SineEase EasingMode="EaseInOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </TextBlock.Triggers>
                            </TextBlock>

                            <!-- Glow Layer 2: Intense tight glow (S rank and above) -->
                            <TextBlock Text="{Binding GradeDisplayName}"
                                       FontSize="80"
                                       FontWeight="Bold"
                                       Foreground="{Binding GradeBrush}"
                                       HorizontalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding IsHighGrade, Converter={StaticResource BoolToVis}}">
                                <TextBlock.Effect>
                                    <BlurEffect Radius="15" />
                                </TextBlock.Effect>
                                <TextBlock.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="Opacity"
                                                    From="0.3" To="0.8"
                                                    Duration="0:0:1.8">
                                                    <DoubleAnimation.EasingFunction>
                                                        <SineEase EasingMode="EaseInOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </TextBlock.Triggers>
                            </TextBlock>

                            <!-- Glow Layer 3: Extra wide halo (SSS+ only) -->
                            <TextBlock Text="{Binding GradeDisplayName}"
                                       FontSize="80"
                                       FontWeight="Bold"
                                       Foreground="{Binding GradeBrush}"
                                       HorizontalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding IsMaxGrade, Converter={StaticResource BoolToVis}}">
                                <TextBlock.Effect>
                                    <BlurEffect Radius="60" />
                                </TextBlock.Effect>
                                <TextBlock.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="Opacity"
                                                    From="0.15" To="0.5"
                                                    Duration="0:0:3">
                                                    <DoubleAnimation.EasingFunction>
                                                        <SineEase EasingMode="EaseInOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </TextBlock.Triggers>
                            </TextBlock>

                            <!-- Main grade text (crisp, on top) -->
                            <TextBlock Text="{Binding GradeDisplayName}"
                                       FontSize="80"
                                       FontWeight="Bold"
                                       Foreground="{Binding GradeBrush}"
                                       HorizontalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect
                                        Color="{Binding GradeBrush.Color}"
                                        BlurRadius="8"
                                        ShadowDepth="0"
                                        Opacity="0.5" />
                                </TextBlock.Effect>
                            </TextBlock>
                        </Grid>

                        <!-- Score -->
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Opacity="0.8"
                                   Margin="0,4,0,0"
                                   Foreground="{Binding GradeBrush}">
                            <Run Text="{Binding GradeScore, Mode=OneWay}" /><Run Text=" / 100" />
                        </TextBlock>

                        <!-- Description -->
                        <TextBlock Text="{Binding GradeDescription}"
                                   FontSize="14"
                                   Opacity="0.5"
                                   Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <!-- Summary -->
                        <TextBlock Text="{Binding ScanSummary}"
                                   FontSize="13"
                                   Opacity="0.4"
                                   Margin="0,4,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>
                    </Grid>
                </Border>

                <!-- Welcome message (visible before first scan) -->
                <StackPanel HorizontalAlignment="Center"
                            Margin="0,32,0,16">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasScanned}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock x:Name="WelcomeTitle"
                               Text="EventScanner"
                               FontSize="36"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="White">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00FFFF" BlurRadius="20" ShadowDepth="0" Opacity="0.4" />
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="System Health &amp; Security Scanner"
                               FontSize="16"
                               Margin="0,4,0,0"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Opacity="0.6" />
                    <TextBlock Text="Scan your system or import .evtx files for forensic analysis"
                               FontSize="13"
                               Margin="0,16,0,0"
                               HorizontalAlignment="Center"
                               Opacity="0.4"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                </StackPanel>

                <!-- Scanning Progress -->
                <StackPanel Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"
                            HorizontalAlignment="Center"
                            Margin="0,24,0,16">
                    <ui:ProgressRing IsIndeterminate="True"
                                     Width="48" Height="48"
                                     HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="14"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Center"
                               Opacity="0.7"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                </StackPanel>

                <!-- Scan Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,8">
                    <ui:Button Content="Quick Scan"
                               Appearance="Primary"
                               Icon="{ui:SymbolIcon Flash24}"
                               Command="{Binding QuickScanCommand}"
                               Margin="0,0,12,0"
                               Padding="16,10">
                        <ui:Button.Effect>
                            <DropShadowEffect Color="#00FFFF" BlurRadius="18" ShadowDepth="0" Opacity="0.6" />
                        </ui:Button.Effect>
                    </ui:Button>
                    <ui:Button Content="Deep Scan"
                               Icon="{ui:SymbolIcon SearchSquare24}"
                               Command="{Binding DeepScanCommand}"
                               Margin="0,0,12,0"
                               Padding="16,10">
                        <ui:Button.Effect>
                            <DropShadowEffect Color="#FF00FF" BlurRadius="18" ShadowDepth="0" Opacity="0.6" />
                        </ui:Button.Effect>
                    </ui:Button>
                    <ui:Button Content="Import Logs"
                               Appearance="Secondary"
                               Icon="{ui:SymbolIcon ArrowImport24}"
                               Command="{Binding ImportLogsCommand}"
                               Margin="0,0,12,0"
                               Padding="16,10">
                        <ui:Button.Effect>
                            <DropShadowEffect Color="#39FF14" BlurRadius="18" ShadowDepth="0" Opacity="0.6" />
                        </ui:Button.Effect>
                    </ui:Button>
                    <ui:Button Content="CTF speed"
                               ToolTip="Import .evtx — same full rules and grade; findings sorted for fast triage"
                               Icon="{ui:SymbolIcon Timer24}"
                               Command="{Binding CtfSpeedImportCommand}"
                               Margin="0,0,12,0"
                               Padding="16,10">
                        <ui:Button.Effect>
                            <DropShadowEffect Color="#FF6B35" BlurRadius="18" ShadowDepth="0" Opacity="0.55" />
                        </ui:Button.Effect>
                    </ui:Button>
                    <ui:Button Content="Export Report"
                               Appearance="Secondary"
                               Icon="{ui:SymbolIcon Save24}"
                               Command="{Binding ExportReportCommand}"
                               Padding="16,10">
                        <ui:Button.Effect>
                            <DropShadowEffect Color="#FFFF00" BlurRadius="18" ShadowDepth="0" Opacity="0.6" />
                        </ui:Button.Effect>
                    </ui:Button>
                </StackPanel>
                <TextBlock Text="{Binding SessionModeHint}"
                           FontSize="11"
                           Opacity="0.75"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           MaxWidth="560"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"
                           Visibility="{Binding SessionModeHint, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />
                <TextBlock Text="Import .evtx files exported from any Windows machine"
                           FontSize="11"
                           Opacity="0.3"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                <!-- Error Message -->
                <ui:InfoBar Title="Scan Error"
                            Message="{Binding ErrorMessage}"
                            Severity="Error"
                            IsOpen="{Binding ErrorMessage.Length, Mode=OneWay}"
                            Margin="0,0,0,12" />

                <!-- Findings List (visible after scanning) -->
                <StackPanel Visibility="{Binding HasScanned, Converter={StaticResource BoolToVis}}">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                        <Run Text="Findings (" /><Run Text="{Binding Findings.Count, Mode=OneWay}" /><Run Text=")" />
                    </TextBlock>

                    <!-- Selectable findings list — click a finding to see its details below -->
                    <ListBox ItemsSource="{Binding Findings}"
                             SelectedItem="{Binding SelectedFinding}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="2" />
                                <Setter Property="Margin" Value="0,0,0,6" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="1.5" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="10"
                                                    Padding="{TemplateBinding Padding}"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#0CFFFFFF" />
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource WaveSelectionBrush}" />
                                                    <Setter TargetName="Bd" Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect Color="#00FFFF" BlurRadius="12" ShadowDepth="0" Opacity="0.3" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#08FFFFFF" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0AFFFFFF"
                                        CornerRadius="8"
                                        Padding="16,12"
                                        BorderThickness="1"
                                        BorderBrush="Transparent"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                    </Border.RenderTransform>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#14FFFFFF" />
                                                    <Setter Property="BorderBrush" Value="#20FFFFFF" />
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                                 To="1.015" Duration="0:0:0.15" />
                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                                 To="1.015" Duration="0:0:0.15" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                                 To="1.0" Duration="0:0:0.2" />
                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                                 To="1.0" Duration="0:0:0.2" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Severity badge with color -->
                                        <Border Grid.Column="0" Grid.RowSpan="2"
                                                CornerRadius="4"
                                                Padding="8,4"
                                                Margin="0,0,12,0"
                                                VerticalAlignment="Center"
                                                Background="{Binding Severity, Converter={StaticResource SeverityToBg}}">
                                            <TextBlock Text="{Binding Severity}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding Severity, Converter={StaticResource SeverityToColor}}" />
                                        </Border>

                                        <TextBlock Grid.Column="1" Grid.Row="0"
                                                   Text="{Binding Title}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                                        <TextBlock Grid.Column="1" Grid.Row="1"
                                                   Text="{Binding Description}"
                                                   FontSize="12"
                                                   Opacity="0.6"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                                        <StackPanel Grid.Column="2" Grid.RowSpan="2"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Right"
                                                    Margin="12,0,0,0">
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="11"
                                                       Opacity="0.5"
                                                       HorizontalAlignment="Right"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <TextBlock FontSize="11"
                                                       Opacity="0.4"
                                                       HorizontalAlignment="Right"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                                <Run Text="{Binding OccurrenceCount, Mode=OneWay}" /><Run Text="x" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- No findings message -->
                    <TextBlock Text="No issues found &#x2014; your system looks great!"
                               FontSize="14"
                               Opacity="0.5"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Findings.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- ═══ FINDING DETAIL PANEL ═══ -->
                <!-- Appears when a finding is selected in the list above -->
                <Border Margin="0,16,0,0"
                        Background="#0CFFFFFF"
                        CornerRadius="12"
                        Padding="24,20">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedFinding}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                    <StackPanel DataContext="{Binding SelectedFinding}">

                        <!-- Header: Title + Severity + Category -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Title}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Border CornerRadius="4" Padding="8,3" Margin="0,0,8,0"
                                            Background="{Binding Severity, Converter={StaticResource SeverityToBg}}">
                                        <TextBlock Text="{Binding Severity}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{Binding Severity, Converter={StaticResource SeverityToColor}}" />
                                    </Border>
                                    <Border CornerRadius="4" Padding="8,3" Background="#10FFFFFF" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding Category}" FontSize="11" Opacity="0.7"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    </Border>
                                    <Border CornerRadius="4" Padding="8,3" Background="#10FFFFFF">
                                        <TextBlock FontSize="11" Opacity="0.7"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                            <Run Text="Confidence: " /><Run Text="{Binding Confidence, Mode=OneWay}" />
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       FontSize="13" Opacity="0.5"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <Run Text="{Binding OccurrenceCount, Mode=OneWay}" /><Run Text=" occurrences" />
                            </TextBlock>
                        </Grid>

                        <!-- Explanation -->
                        <TextBlock Text="Explanation"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="{Binding Explanation}"
                                   FontSize="13" TextWrapping="Wrap" Opacity="0.8" Margin="0,0,0,16"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <!-- Why It Matters -->
                        <TextBlock Text="Why It Matters"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="{Binding WhyItMatters}"
                                   FontSize="13" TextWrapping="Wrap" Opacity="0.8" Margin="0,0,0,16"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <!-- Possible Causes -->
                        <TextBlock Text="Possible Causes"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <ItemsControl ItemsSource="{Binding PossibleCauses}" Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontSize="13" Opacity="0.8" Margin="8,2,0,2"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                        <Run Text="&#x2022;  " /><Run Text="{Binding Mode=OneWay}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Event Timeline Grid -->
                        <TextBlock FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                            <Run Text="Event Timeline (" /><Run Text="{Binding MatchedEvents.Count, Mode=OneWay}" /><Run Text=" events)" />
                        </TextBlock>
                        <DataGrid ItemsSource="{Binding MatchedEvents}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserSortColumns="True"
                                  CanUserReorderColumns="False"
                                  CanUserResizeColumns="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  MaxHeight="350"
                                  BorderThickness="1"
                                  BorderBrush="#20FFFFFF"
                                  Background="Transparent"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="#06FFFFFF">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Timestamp"
                                                    Binding="{Binding TimeCreated, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                                    Width="160" />
                                <DataGridTextColumn Header="Event ID"
                                                    Binding="{Binding EventId}"
                                                    Width="75" />
                                <DataGridTextColumn Header="Level"
                                                    Binding="{Binding Level}"
                                                    Width="100" />
                                <DataGridTextColumn Header="Provider"
                                                    Binding="{Binding ProviderName}"
                                                    Width="180" />
                                <DataGridTextColumn Header="Message"
                                                    Binding="{Binding Message}"
                                                    Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                            <Setter Property="ToolTip" Value="{Binding Message}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                    </StackPanel>

                    <!-- CTF-only: heuristic pivots from raw messages (parent DataContext = dashboard) -->
                    <Border Margin="0,16,0,0"
                            Padding="14,12"
                            Background="#14FFFFFF"
                            CornerRadius="8"
                            BorderBrush="#18FFFFFF"
                            BorderThickness="1"
                            Visibility="{Binding ShowCtfEntityPanel, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="CTF pivots (auto-detected)"
                                       FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="Heuristic only — verify in context. Empty or generic messages limit what can be parsed."
                                       FontSize="11" TextWrapping="Wrap" Opacity="0.55" Margin="0,0,0,10"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                            <ItemsControl ItemsSource="{Binding CtfExtractedPivots}"
                                          Visibility="{Binding CtfPivotsHasRows, Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock TextWrapping="Wrap" Margin="0,3,0,0"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                            <Run Text="{Binding Category, Mode=OneWay}" FontWeight="SemiBold" />
                                            <Run Text=" · " Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                            <Run Text="{Binding Value, Mode=OneWay}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="No IPv4s, paths, DOMAIN\user-style accounts, emails, or computer names were parsed from these events."
                                       FontSize="12" TextWrapping="Wrap" Opacity="0.6"
                                       Visibility="{Binding ShowCtfPivotsPlaceholder, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border x:Name="StatusBar"
                Grid.Row="2"
                Background="#0A0A1A"
                BorderThickness="0,1.5,0,0"
                Padding="16,8">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12"
                       Opacity="0.6"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
        </Border>

    </Grid>
    </Grid>
</ui:FluentWindow>
